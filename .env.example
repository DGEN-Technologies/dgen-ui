# ================================
# DGEN UI Environment Variables
# ================================
# Copy this file to .env and fill in your values
# These are the minimal required variables for both development and production

# Environment (REQUIRED)
NODE_ENV=development  # Use 'production' for Netlify/Vercel

# Core API Configuration (REQUIRED)
# Development: Point to local server
# Production: Point to your Railway API
PUBLIC_DGEN_URL=http://localhost:3119  # Production: https://your-api.railway.app

# WebSocket Connection (REQUIRED)
# Development: ws://localhost
# Production: wss://your-domain
PUBLIC_SOCKET=ws://localhost:3119/ws  # Production: wss://your-api.railway.app/ws

# Domain (OPTIONAL - auto-detected in most cases)
# Only needed if auto-detection fails
PUBLIC_DOMAIN=localhost:5173  # Production: your-app.netlify.app

# Blockchain Configuration (REQUIRED)
PUBLIC_DGEN_NETWORK=mainnet  # Options: mainnet, testnet, regtest

# Block Explorers (REQUIRED)
PUBLIC_EXPLORER=https://blockstream.info
PUBLIC_LIQUID_EXPLORER=https://blockstream.info/liquid

# Breez SDK Esplora Overrides (OPTIONAL)
# Use the backend proxy so the paid Blockstream key is applied server-side
VITE_LIQUID_EXPLORER_URL=http://localhost:3119/api/esplora/liquid  # Production: https://your-api.railway.app/api/esplora/liquid
VITE_BITCOIN_EXPLORER_URL=http://localhost:3119/api/esplora/bitcoin  # Production: https://your-api.railway.app/api/esplora/bitcoin

# Breez SDK API Key (REQUIRED for Lightning features)
# Get your API key from https://sdk-doc.breez.technology/
VITE_BREEZ_API_KEY=your-breez-api-key-here

# Chatbot Configuration
PUBLIC_WIDGET_API_BASE="https://widget2agent-657488364208.asia-southeast1.run.app"
PUBLIC_ORG_ID="dgen-dev"

# SwapSpace Widget (REQUIRED for Swap feature)
# Configure your widget at https://swapspace.co/affiliate/widget
PUBLIC_SWAPSPACE_WIDGET_URL=https://swapspace.co/widget/b04b927eb4e70d06b09928eb

# DGEN Mastercard is live Url
PUBLIC_MASTERCARD_IS_LIVE_URL = https://card.dgentech.io/pages/r?c=AMeaqiij